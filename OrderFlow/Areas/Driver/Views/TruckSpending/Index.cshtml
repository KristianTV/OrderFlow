@using OrderFlow.ViewModels.TruckSpending
@model IEnumerable<IndexTruckSpendingViewModel>
@{
    ViewData["Title"] = "Truck Spendings";
    var trucks = ViewBag.Trucks as IDictionary<Guid, string> ?? new Dictionary<Guid, string>();
    var courses = ViewBag.Courses as IDictionary<Guid, string> ?? new Dictionary<Guid, string>();
    Guid? currentTruckId = ViewBag.CurrentTruckId as Guid?;
    Guid? currentCourseId = ViewBag.CurrentCourseId as Guid?;
    string currentSearch = ViewBag.CurrentSearch as string ?? string.Empty;
    string currentSortOrder = ViewBag.CurrentSortOrder as string ?? string.Empty;
    bool hasMore = ViewBag.HasMore as bool? ?? false;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-primary">@ViewData["Title"]</h1>
        <a class="btn btn-success btn-lg shadow-sm" asp-area="Driver" asp-controller="TruckSpending" asp-action="Create">
            <i class="fas fa-plus-circle me-2"></i> Create Spending
        </a>
    </div>

    <form asp-area="Driver" asp-controller="TruckSpending" asp-action="Index" method="get" class="card shadow-sm mb-4" id="spendingFilterForm">
        <div class="card-body row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="truckId">Truck</label>
                <select class="form-select" id="truckId" name="truckId">
                    <option value="">All trucks</option>
                    @foreach (var truck in trucks)
                    {
                        <option value="@truck.Key" selected="@(currentTruckId == truck.Key)">@truck.Value</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="courseId">Course</label>
                <select class="form-select" id="courseId" name="courseId">
                    <option value="">All courses</option>
                    @foreach (var course in courses)
                    {
                        <option value="@course.Key" selected="@(currentCourseId == course.Key)">@course.Value</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="search">Search</label>
                <input class="form-control" id="search" name="search" value="@currentSearch" placeholder="Description" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="sortOrder">Sort</label>
                <select class="form-select" id="sortOrder" name="sortOrder">
                    <option value="" selected="@(string.IsNullOrEmpty(currentSortOrder))">Newest first</option>
                    <option value="date_asc" selected="@(currentSortOrder == "date_asc")">Oldest first</option>
                    <option value="amount_desc" selected="@(currentSortOrder == "amount_desc")">Amount high</option>
                    <option value="amount_asc" selected="@(currentSortOrder == "amount_asc")">Amount low</option>
                </select>
            </div>
            <div class="col-md-1 d-grid">
                <button class="btn btn-primary" type="submit"><i class="fas fa-filter"></i></button>
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Truck</th>
                    <th>Course</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Method</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="spendingResults">
                <partial name="_SpendingList" model="Model" />
            </tbody>
        </table>
    </div>

    <div id="spendingEmpty" class="alert alert-info shadow-sm mt-3 @(Model != null && Model.Any() ? "d-none" : "")">No truck spendings found.</div>

    <div id="spendingSentinel" class="text-center text-muted py-4 @(hasMore ? "" : "d-none")" data-page="1" data-has-more="@hasMore.ToString().ToLowerInvariant()">
        <span class="spinner-border spinner-border-sm me-2"></span>Loading more spendings...
    </div>
</div>

@section Scripts {
    <script src="~/js/View/Shared/endless-scroll.js" asp-append-version="true"></script>
    <script src="~/js/View/Shared/truck-spending.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            setupTruckSpendingIndex({
                formId: "spendingFilterForm",
                resultsId: "spendingResults",
                truckSelectId: "truckId",
                courseSelectId: "courseId",
                sentinelId: "spendingSentinel",
                emptyId: "spendingEmpty",
                coursesUrl: "@Url.Action("Courses", "TruckSpending", new { area = "Driver" })",
                placeholder: "All courses",
                disableWithoutTruck: false
            });
        });
    </script>
}
