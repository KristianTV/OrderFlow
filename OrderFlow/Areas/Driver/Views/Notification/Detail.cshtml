@using OrderFlow.ViewModels.Notification
@model DriverDetailsNotificationViewModel;
@{
    ViewData["Title"] = "Notification Details";
    var notificationID = Context.Request.RouteValues["id"]?.ToString() ?? "";
    bool messagesEnabled = Model.IsResponseEnabled;
    Guid currentUserId = ViewBag.CurrentUserId ?? Guid.Empty;
}

<div class="container mt-5">
    <h2 class="mb-4 text-center text-primary">@ViewData["Title"]</h2>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg mb-4 border-light">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        @if (Model.IsRead)
                        {
                            <i class="far fa-envelope-open me-2"></i>
                        }
                        else
                        {
                            <i class="fas fa-envelope me-2"></i>
                        }
                        @Model.Title
                    </h4>
                    <span class="badge @(Model.IsRead ? "bg-light text-dark" : "bg-warning") fs-6">
                        @(Model.IsRead ? "Read" : "Unread")
                    </span>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Created At:</div>
                        <div class="col-sm-8"><i class="far fa-clock me-1"></i> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.SenderName))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">From:</div>
                            <div class="col-sm-8"><i class="fas fa-user me-1"></i> @Model.SenderName</div>
                        </div>
                    }

                    @if (Model.TruckId.HasValue)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Truck:</div>
                            <div class="col-sm-8">
                                <a asp-area="Driver" asp-controller="Truck" asp-action="Detail"
                                       asp-route-id="@Model.TruckId" class="text-decoration-none">
                                    <i class="fas fa-truck me-1"></i> View Associated Truck <i class="fa-solid fa-share-from-square"></i>
                                </a>
                            </div>
                        </div>
                    }

                    @if (Model.CourseId.HasValue)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Course:</div>
                            <div class="col-sm-8">
                                <a asp-area="Driver" asp-controller="Course" asp-action="Detail"
                                       asp-route-id="@Model.CourseId" class="text-decoration-none">
                                    <i class="fas fa-book me-1"></i> View Associated Course <i class="fa-solid fa-share-from-square"></i>
                                </a>
                            </div>
                        </div>
                    }

                    @if (Model.TruckSpendingId.HasValue)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Truck Spending:</div>
                            <div class="col-sm-8">
                                <a asp-area="Driver" asp-controller="TruckSpending" asp-action="Detail"
                                       asp-route-id="@Model.TruckSpendingId" class="text-decoration-none">
                                    <i class="fas fa-credit-card me-1"></i> View Associated Truck Spending <i class="fa-solid fa-share-from-square"></i>
                                </a>
                            </div>
                        </div>
                    }
                    <hr />
                    <h5 class="mt-3 mb-2">Message:</h5>
                    <p class="card-text">@Model.Message</p>
                </div>
                <div class="card-footer text-end bg-light border-top-0 d-flex justify-content-between align-items-center">
                    <a class="btn btn-secondary btn-lg" asp-area="Driver" asp-action="Index" asp-controller="Notification">
                        <i class="fas fa-arrow-left me-2"></i> Back to All Notifications
                    </a>
                    <div>
                        @if (Model.IsRead)
                        {
                            <form asp-antiforgery="true" asp-controller="Notification" asp-area="Driver" asp-action="MarkAsUnread" asp-route-id="@notificationID" method="post" class="d-inline me-2">
                                <button type="submit" class="btn btn-warning btn-lg">
                                    <i class="fas fa-eye-slash me-2"></i> Mark as Unread
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-antiforgery="true" asp-controller="Notification" asp-area="Driver" asp-action="MarkAsRead" asp-route-id="@notificationID" method="post" class="d-inline me-2">
                                <button type="submit" class="btn btn-info btn-lg">
                                    <i class="fas fa-check-circle me-2"></i> Mark as Read
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
            @if (messagesEnabled)
            {
                <partial name="~/Views/Message/Index.cshtml" model="Model" />
            }
        </div>
    </div>
</div>

 @section Scripts {
      <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

     <script>
        const notificationID  = '@notificationID';
        const currentUserId = '@currentUserId';
    </script>

    <script src="~/js/sonar/message.js"></script>

    <script src="~/js/View/Shared/Notification/Detail.js"></script>'
    
    <partial name="_ToastContainer" />
}
