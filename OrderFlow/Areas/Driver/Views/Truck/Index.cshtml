@using OrderFlow.ViewModels.Truck
@model IEnumerable<IndexTruckViewModel>
@{
    ViewData["Title"] = "All Trucks";
    ViewData["TruckArea"] = "Driver";
    var currentStatus = ViewData["CurrentStatus"] as string ?? "All";
    var currentSearch = ViewData["CurrentSearch"] as string ?? string.Empty;
    var currentSortOrder = ViewData["CurrentSortOrder"] as string ?? string.Empty;
    bool hasMore = ViewBag.HasMore as bool? ?? false;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-center flex-grow-1 text-primary">@ViewData["Title"]</h1>
    </div>

    <form asp-area="Driver" asp-controller="Truck" asp-action="Index" method="get" class="mb-4 p-3 border rounded shadow-sm bg-light" id="trucksFilterForm">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="search" class="form-label visually-hidden">Search by license plate or driver</label>
                <div class="input-group">
                    <input type="search" class="form-control" id="search" name="search" placeholder="Search by license plate or driver" value="@currentSearch" />
                    <button type="submit" class="btn btn-outline-primary"><i class="fas fa-search"></i> Search</button>
                </div>
            </div>
            <div class="col-md-3">
                <label for="status" class="form-label">Filter by Status:</label>
                <select id="status" name="status" class="form-select">
                    <option value="" selected="@(currentStatus == "All")">All Statuses</option>
                    <option value="Available" selected="@(currentStatus == "Available")">Available</option>
                    <option value="Unavailable" selected="@(currentStatus == "Unavailable")">Unavailable</option>
                    <option value="UnderMaintenance" selected="@(currentStatus == "UnderMaintenance")">Under Maintenance</option>
                    <option value="Delayed" selected="@(currentStatus == "Delayed")">Delayed</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="sortOrder" class="form-label">Sort by:</label>
                <select id="sortOrder" name="sortOrder" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(currentSortOrder))">Status</option>
                    <option value="status_desc" selected="@(currentSortOrder == "status_desc")">Status descending</option>
                    <option value="license_asc" selected="@(currentSortOrder == "license_asc")">License plate A-Z</option>
                    <option value="license_desc" selected="@(currentSortOrder == "license_desc")">License plate Z-A</option>
                    <option value="driver_asc" selected="@(currentSortOrder == "driver_asc")">Driver A-Z</option>
                    <option value="driver_desc" selected="@(currentSortOrder == "driver_desc")">Driver Z-A</option>
                </select>
            </div>
        </div>
    </form>

    <div id="trucksList" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <partial name="~/Views/Shared/_TruckCards.cshtml" model="Model" />
    </div>

    <div id="trucksEmpty" class="col-md-6 mx-auto @(Model != null && Model.Any() ? "d-none" : "")">
        <div class="alert alert-info text-center shadow-sm" role="alert">
            <h4 class="alert-heading"><i class="fas fa-info-circle me-2"></i> No Trucks Found</h4>
            <p class="mb-0">It looks like there are no trucks to display yet.</p>
        </div>
    </div>

    <div id="trucksSentinel" class="text-center text-muted py-4 @(hasMore ? "" : "d-none")" data-page="1" data-has-more="@hasMore.ToString().ToLowerInvariant()">
        <span class="spinner-border spinner-border-sm me-2"></span>Loading more trucks...
    </div>
</div>

@section Scripts {
    <script src="~/js/View/Shared/endless-scroll.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            setupEndlessIndex({ formId: "trucksFilterForm", listId: "trucksList", sentinelId: "trucksSentinel", emptyId: "trucksEmpty" });
        });
    </script>
}
