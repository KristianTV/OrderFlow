@using OrderFlow.ViewModels.TruckSpending
@model CreateTruckSpendingViewModel
@{
    ViewData["Title"] = "Edit Truck Spending";
    Guid spendingId = ViewBag.SpendingId ?? Guid.Empty;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-lg mt-5">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">@ViewData["Title"]</h3>
            </div>
            <div class="card-body">
                <form asp-antiforgery="true" asp-area="Admin" asp-controller="TruckSpending" asp-action="Edit" asp-route-id="@spendingId" method="post" id="editSpendingForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <partial name="_SpendingFormFields" model="Model" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-area="Admin" asp-controller="TruckSpending" asp-action="Detail" asp-route-id="@spendingId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Back
                        </a>
                        <button type="submit" id="saveBtn" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/View/Shared/truck-spending.js" asp-append-version="true"></script>
    <script src="~/js/View/Shared/track-changes.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            setupTruckCourseFilter({
                truckSelectId: "TruckID",
                courseSelectId: "TruckCourseID",
                coursesUrl: "@Url.Action("Courses", "TruckSpending", new { area = "Admin" })",
                placeholder: "-- Select Course --",
                disableWithoutTruck: true
            });
            watchFormChanges("editSpendingForm", "saveBtn");
        });
    </script>
}
