@using OrderFlow.ViewModels.TruckSpending
@model IEnumerable<IndexTruckSpendingViewModel>

@foreach (var spending in Model ?? Enumerable.Empty<IndexTruckSpendingViewModel>())
{
    <tr>
        <td>@spending.TruckLicensePlate</td>
        <td>@spending.CourseDescription</td>
        <td>@spending.PaymentDescription</td>
        <td>@spending.PaymentDate.ToString("dd/MM/yyyy")</td>
        <td><span class="badge bg-secondary">@spending.PaymentMethod</span></td>
        <td class="text-end">@spending.Amount.ToString("C")</td>
        <td class="text-end">
            <a class="btn btn-sm btn-primary" asp-area="Admin" asp-controller="TruckSpending" asp-action="Detail" asp-route-id="@spending.TruckSpendingID">
                <i class="fas fa-info-circle"></i>
            </a>
            <a class="btn btn-sm btn-warning" asp-area="Admin" asp-controller="TruckSpending" asp-action="Edit" asp-route-id="@spending.TruckSpendingID">
                <i class="fas fa-edit"></i>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <form asp-area="Admin" asp-controller="TruckSpending" asp-action="Delete" asp-route-id="@spending.TruckSpendingID" method="post" class="d-inline">
                    <button class="btn btn-sm btn-danger" type="submit" onclick="return confirm('Delete this truck spending?');">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            }
        </td>
    </tr>
}
