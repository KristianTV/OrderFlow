@using OrderFlow.ViewModels.Course
@model IEnumerable<IndexCourseViewModel>
@{
    ViewData["Title"] = "All Courses";
    ViewData["CourseArea"] = "Admin";

    var currentHideCompleted = Context.Request.Query["hideCompleted"].FirstOrDefault() == "true";
    var currentStatusFilter = Context.Request.Query["statusFilter"].FirstOrDefault();
    var currentSearchId = Context.Request.Query["searchId"].FirstOrDefault();
    var currentSortOrder = Context.Request.Query["sortOrder"].FirstOrDefault();
    bool hasMore = ViewBag.HasMore as bool? ?? false;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-center flex-grow-1 text-primary">@ViewData["Title"]</h1>
        <a class="btn btn-success btn-lg shadow-sm" asp-area="Admin" asp-controller="Course" asp-action="Create">
            <i class="fas fa-plus-circle me-2"></i> Create New Course
        </a>
    </div>

    <form asp-area="Admin" asp-controller="Course" asp-action="Index" method="get" class="mb-4 p-3 border rounded shadow-sm bg-light" id="coursesFilterForm">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="searchId" class="form-label visually-hidden">Search by Course ID</label>
                <div class="input-group">
                    <input type="search" class="form-control" id="searchId" name="searchId" placeholder="Search by Course ID" value="@currentSearchId" />
                    <button type="submit" class="btn btn-outline-primary"><i class="fas fa-search"></i> Search</button>
                </div>
            </div>
            <div class="col-md-3">
                <label for="statusFilter" class="form-label">Filter by Status:</label>
                <select id="statusFilter" name="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(currentStatusFilter == "Pending")">Pending</option>
                    <option value="Assigned" selected="@(currentStatusFilter == "Assigned")">Assigned</option>
                    <option value="Loaded" selected="@(currentStatusFilter == "Loaded")">Loaded</option>
                    <option value="Delivered" selected="@(currentStatusFilter == "Delivered")">Delivered</option>
                    <option value="Cancelled" selected="@(currentStatusFilter == "Cancelled")">Cancelled</option>
                    <option value="Delayed" selected="@(currentStatusFilter == "Delayed")">Delayed</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input" type="checkbox" id="hideCompleted" name="hideCompleted" value="true" @(currentHideCompleted ? "checked" : "")>
                    <label class="form-check-label" for="hideCompleted">Hide Completed Courses</label>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Sort by Date:</label>
                <div class="btn-group w-100" role="group">
                    <button type="submit" name="sortOrder" value="date_asc" class="btn btn-outline-info btn-sm @(currentSortOrder == "date_asc" ? "active" : "")">
                        <i class="fas fa-sort-amount-down me-1"></i> Ascending
                    </button>
                    <button type="submit" name="sortOrder" value="date_desc" class="btn btn-outline-info btn-sm @(currentSortOrder == "date_desc" || string.IsNullOrEmpty(currentSortOrder) ? "active" : "")">
                        <i class="fas fa-sort-amount-up me-1"></i> Descending
                    </button>
                </div>
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm border rounded-3">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-primary text-center">
                <tr>
                    <th>Course ID</th>
                    <th>Truck</th>
                    <th>Pickup Address</th>
                    <th>Delivery Address</th>
                    <th>Assigned Date</th>
                    <th>Delivery Date</th>
                    <th>Status</th>
                    <th>Income</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="coursesList">
                <partial name="~/Views/Shared/_CourseRows.cshtml" model="Model" />
            </tbody>
        </table>
    </div>

    <div id="coursesEmpty" class="alert alert-info text-center shadow-sm mt-3 @(Model != null && Model.Any() ? "d-none" : "")">
        <i class="fas fa-info-circle me-2"></i>No courses found.
    </div>

    <div id="coursesSentinel" class="text-center text-muted py-4 @(hasMore ? "" : "d-none")" data-page="1" data-has-more="@hasMore.ToString().ToLowerInvariant()">
        <span class="spinner-border spinner-border-sm me-2"></span>Loading more courses...
    </div>
</div>

@section Scripts {
    <script src="~/js/View/Shared/endless-scroll.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            setupEndlessIndex({ formId: "coursesFilterForm", listId: "coursesList", sentinelId: "coursesSentinel", emptyId: "coursesEmpty" });
        });
    </script>
}
