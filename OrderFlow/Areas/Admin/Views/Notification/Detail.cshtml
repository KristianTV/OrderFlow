@using OrderFlow.ViewModels.Notification
@using OrderFlow.ViewModels.Message
@model DriverDetailsNotificationViewModel;
@{
    ViewData["Title"] = "Notification Details";
    string notificationID = Context.Request.RouteValues["id"]?.ToString() ?? "";
    bool messagesEnabled = Model.IsResponseEnabled;
}

<div class="container mt-5">
    <h2 class="mb-4 text-center text-primary">@ViewData["Title"]</h2>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg mb-4 @(Model.IsRead ? "border-light" : "border-primary")">
                <div class="card-header @(Model.IsRead ? "bg-secondary" : "bg-primary") text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        @if (Model.IsRead)
                        {
                            <i class="far fa-envelope-open me-2"></i>
                        }
                        else
                        {
                            <i class="fas fa-envelope me-2"></i>
                        }
                        @Model.Title
                    </h4>
                    <span class="badge @(Model.IsRead ? "bg-light text-dark" : "bg-warning") fs-6">
                        @(Model.IsRead ? "Read" : "Unread")
                    </span>
                </div>

                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Created At:</div>
                        <div class="col-sm-8">
                            <i class="far fa-clock me-1"></i> @Model.CreatedAt.ToString("dd-MM-yyyy HH:mm")
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SenderName))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">From:</div>
                            <div class="col-sm-8"><i class="fas fa-user me-1"></i> @Model.SenderName</div>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">From:</div>
                            <div class="col-sm-8"><i class="fas fa-user me-1"></i> System</div>
                        </div>
                    }

                    @if (Model.OrderId.HasValue)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Order:</div>
                            <div class="col-sm-8">
                                <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                                   asp-route-id="@Model.OrderId" class="text-decoration-none">
                                    <i class="fas fa-box-open me-1"></i> View Associated Order
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Order:</div>
                            <div class="col-sm-8">
                                <p class="mb-0 text-muted fst-italic">No order associated.</p>
                            </div>
                        </div>
                    }

                    @if (Model.TruckId.HasValue)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Truck:</div>
                            <div class="col-sm-8">
                                <a asp-area="Admin" asp-controller="Truck" asp-action="Detail"
                                   asp-route-id="@Model.TruckId" class="text-decoration-none">
                                    <i class="fas fa-truck me-1"></i> View Associated Truck
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Associated Truck:</div>
                            <div class="col-sm-8">
                                <p class="mb-0 text-muted fst-italic">No truck associated.</p>
                            </div>
                        </div>
                    }

                    <hr />
                    <h5 class="mt-3 mb-2">Message:</h5>
                    <p class="card-text">@Model.Message</p>
                </div>

                <div class="card-footer text-end bg-light border-top-0 d-flex justify-content-between align-items-center">
                    <a class="btn btn-secondary btn-lg"
                       asp-area="Admin" asp-action="Index" asp-controller="Notification">
                        <i class="fas fa-arrow-left me-2"></i> Back to All Notifications
                    </a>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.SenderName))
                        {
                            <a class="btn btn-primary btn-lg me-2"
                               asp-area="Admin" asp-action="Edit" asp-controller="Notification"
                               asp-route-id="@notificationID">
                                <i class="fas fa-edit me-2"></i> Edit
                            </a>
                        }

                        @if (Model.isMarkable)
                        {
                            @if (Model.IsRead)
                            {
                                <form asp-antiforgery="true"
                                      asp-area="Admin" asp-controller="Notification"
                                      asp-action="MarkAsUnread" asp-route-id="@notificationID"
                                      method="post" class="d-inline me-2">
                                    <button type="submit" class="btn btn-warning btn-lg">
                                        <i class="fas fa-eye-slash me-2"></i> Mark as Unread
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-antiforgery="true"
                                      asp-area="Admin" asp-controller="Notification"
                                      asp-action="MarkAsRead" asp-route-id="@notificationID"
                                      method="post" class="d-inline me-2">
                                    <button type="submit" class="btn btn-info btn-lg">
                                        <i class="fas fa-check-circle me-2"></i> Mark as Read
                                    </button>
                                </form>
                            }
                        }

                        <button type="button" class="btn btn-danger btn-lg"
                                data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                            <i class="fas fa-trash-alt me-2"></i> Delete
                        </button>
                    </div>
                </div>
            </div>

            @if (messagesEnabled)
            {
                <partial name="_MessageSection" model="Model" />
            }

        </div>
    </div>
</div>

<partial name="_DeleteModalPartial" model='new { 
    Title = "Confirm Deletion", 
    Message = "Are you sure you want to delete this notification? This cannot be undone.",
    CancelText = "No, Keep Notification",
    ConfirmText = "Yes, Delete Notification",
    Area = "Admin",
    Controller = "Notification",
    Action = "Delete",
    RouteId = notificationID 
}' />

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script>
        const notificationID  = '@notificationID';
    </script>

    <script src="~/js/sonar/message.js"></script>

    <script src="~/js/View/Admin/Notification/Detail.js"></script>

    <partial name="_ToastContainer" />
}
