@using OrderFlow.ViewModels.Notification
@model IEnumerable<DriverIndexNotificationViewModel>;
@{
    ViewData["Title"] = "All Notifications";
    string currentSort = ViewData["CurrentSort"] as string ?? "All";
    bool hideSystemNotifications = ViewData["hideSystemNotifications"] as bool? ?? false;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-center flex-grow-1 text-primary">@ViewData["Title"]</h1>
        <a class="btn btn-success btn-lg shadow-sm" asp-area="Admin" asp-controller="Notification" asp-action="Create">
            <i class="fas fa-plus-circle me-2"></i> Create New Notification
        </a>
    </div>

    <div class="p-3 d-flex justify-content-end mb-3">
        <form method="get" asp-area="Admin" asp-action="Index" asp-controller="Notification" id="notificationFilterForm" class="align-self-center">
            <input type="hidden" name="sortBy" value="@currentSort.ToLowerInvariant()" />
            <div class="form-check form-switch me-3 align-self-center">
                <input class="form-check-input" type="checkbox" id="hideSystemNotifications" name="hideSystemNotifications" value="true" @(hideSystemNotifications ? "checked" : "")>
                <label class="form-check-label" for="hideSystemNotifications">
                    Hide System Notifications
                </label>
            </div>
        </form>
        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" id="sortDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fas fa-sort me-2"></i> Sort By: @currentSort
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="sortDropdown">
                <li><h6 class="dropdown-header">Notification Status</h6></li>
                <li><a class="dropdown-item @(currentSort == "All" ? "active" : "")" asp-area="Admin" asp-controller="Notification" asp-action="Index" asp-route-sortBy="all" data-endless-link data-notification-sort="all">All</a></li>
                <li><a class="dropdown-item @(currentSort == "Unread" ? "active" : "")" asp-area="Admin" asp-controller="Notification" asp-action="Index" asp-route-sortBy="unread" data-endless-link data-notification-sort="unread">Unread</a></li>
                <li><a class="dropdown-item @(currentSort == "Read" ? "active" : "")" asp-area="Admin" asp-controller="Notification" asp-action="Index" asp-route-sortBy="read" data-endless-link data-notification-sort="read">Read</a></li>
            </ul>
        </div>
    </div>

    <div id="notificationsList" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" data-current-sort="@currentSort.ToLowerInvariant()">
        <partial name="~/Views/Shared/_NotificationCards.cshtml" model="Model" />
    </div>

    <div id="notificationsEmpty" class="col-md-6 mx-auto @(Model != null && Model.Any() ? "d-none" : "")">
        <div class="alert alert-info text-center shadow-sm mt-3" role="alert">
            <h4 class="alert-heading"><i class="fas fa-bell me-2"></i> No Notifications Found</h4>
            <p class="mb-0">It looks like there are no notifications to display yet.</p>
        </div>
    </div>

    <div id="notificationsSentinel" class="text-center text-muted py-4 @(ViewBag.HasMore as bool? ?? false ? "" : "d-none")" data-page="1" data-has-more="@((ViewBag.HasMore as bool? ?? false).ToString().ToLowerInvariant())">
        <span class="spinner-border spinner-border-sm me-2"></span>Loading more notifications...
    </div>
</div>

@section Scripts {
    <script src="~/js/View/Shared/endless-scroll.js" asp-append-version="true"></script>
    <script src="~/js/View/Shared/notifications-index.js" asp-append-version="true"></script>
}
