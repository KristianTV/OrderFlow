@using OrderFlow.ViewModels.Notification
@model AdminCreateNotificationViewModel;
@{
    ViewData["Title"] = "Edit Notification";
    Guid id = ViewBag.NotificationId ?? Guid.Empty;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-lg mt-5">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0"><i class="fas fa-bell me-2"></i> @ViewData["Title"]</h3>
            </div>
            <div class="card-body">
                <form id="editNotificationForm"
                    asp-antiforgery="true"
                    asp-area="Admin"
                    asp-controller="Notification"
                    asp-action="Edit"
                    asp-route-id="@id"
                    method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., Order Status Update" />
                        <span asp-validation-for="Title" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Message" class="form-label"></label>
                        <textarea asp-for="Message" class="form-control" rows="4" placeholder="Enter the notification message..."></textarea>
                        <span asp-validation-for="Message" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReceiverId" class="form-label">Receiver</label>
                        <select asp-for="ReceiverId" class="form-select">
                            <option value="">-- Select Receiver --</option>
                            @if (Model.Receivers != null)
                            {
                                foreach (var receiver in Model.Receivers)
                                {
                                    <option value="@receiver.Key">@receiver.Value</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="ReceiverId" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OrderId" class="form-label">Associated Order (Optional)</label>
                        <select asp-for="OrderId" class="form-select">
                            @if (Model.Orders != null && Model.Orders!.Count > 0)
                            {
                                <option value="">-- Select Order --</option>
                            
                                foreach (var order in Model.Orders)
                                {
                                    <option value="@order.Key">@order.Value</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Orders Available --</option>
                            }
                        </select>
                        <span asp-validation-for="OrderId" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TruckId" class="form-label">Associated Truck (Optional)</label>
                        <select asp-for="TruckId" class="form-select">
                            @if (Model.Trucks != null && Model.Trucks!.Count > 0)
                            {
                                <option value="">-- Select Truck --</option>
                                foreach (var truck in Model.Trucks)
                                {
                                    <option value="@truck.Key">@truck.Value</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Trucks Available --</option>
                            }
                        </select>
                        <span asp-validation-for="TruckId" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label">Associated Course (Optional)</label>
                        <select asp-for="CourseId" class="form-select">
                            @if (Model.Courses != null && Model.Courses!.Count > 0)
                            {
                                <option value="">-- Select Course --</option>
                                foreach (var course in Model.Courses)
                                {
                                    <option value="@course.Key">@course.Value</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Courses Available --</option>
                            }
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger mt-1 d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PaymentId" class="form-label">Associated Payment (Optional)</label>
                        <select asp-for="PaymentId" class="form-select">
                            @if (Model.Payments != null && Model.Payments!.Count > 0)
                            {
                                <option value="">-- Select Payment --</option>
                                foreach (var payment in Model.Payments)
                                {
                                    <option value="@payment.Key">@payment.Value</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Payment Available --</option>
                            }
                        </select>
                        <span asp-validation-for="PaymentId" class="text-danger mt-1 d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TruckSpendingId" class="form-label">Associated Truck Spending (Optional)</label>
                        <select asp-for="TruckSpendingId" class="form-select">
                            @if (Model.TruckSpendings != null && Model.TruckSpendings!.Count > 0)
                            {
                                <option value="">-- Select Truck Spending --</option>
                                foreach (var truckSpending in Model.TruckSpendings)
                                {
                                    <option value="@truckSpending.Key">@truckSpending.Value</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Truck Spendings Available --</option>
                            }
                        </select>
                        <span asp-validation-for="TruckSpendingId" class="text-danger mt-1 d-block"></span>
                    </div>
                    <div class="mb-3">
                        <input asp-for="IsResponseEnabled" class="form-check-input" type="checkbox" />
                        <label asp-for="IsResponseEnabled" class="form-check-label"></label>
                        <span asp-validation-for="IsResponseEnabled" class="text-danger mt-1 d-block"></span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-area="Admin" asp-action="Index" asp-controller="Notification" class="btn btn-secondary btn-lg">
                            <i class="fas fa-arrow-left me-2"></i> Cancel
                        </a>
                        <button type="submit" id="saveBtn" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i> Save Notification
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/View/Shared/track-changes.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
                 watchFormChanges("editNotificationForm", "saveBtn");
        });
    </script>
}