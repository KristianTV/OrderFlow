@using Microsoft.AspNetCore.Identity
@using OrderFlow.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrderFlow</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@latest/dist/flatly/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OrderFlow.styles.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary navbar-dark shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">OrderFlow</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="mainNavbarCollapse">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Speditor")))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Order" && currentArea == "Admin" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Order" asp-action="Index">
                                    <i class="fas fa-box-open me-1"></i> Orders
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Truck" && currentArea == "Admin" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Truck" asp-action="Index">
                                    <i class="fas fa-truck me-1"></i> Trucks
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Course" && currentArea == "Admin" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Course" asp-action="Index">
                                    <i class="fa-solid fa-truck-ramp-box me-1"></i> Courses
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Notification" && currentArea == "Admin" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Notification" asp-action="Index">
                                    <i class="fas fa-bell me-1"></i> Notifications
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Role" && currentArea == "Admin" ? "active" : "")"
                                       asp-area="Admin" asp-controller="Role" asp-action="Index">
                                        <i class="fas fa-user-shield me-1"></i> Roles
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Dashboard" && currentArea == "Admin" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="fas fa-chart-line me-1"></i> Dashboard
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>