@using OrderFlow.Data.Models.Enums
@using OrderFlow.ViewModels.User
@model EditProfileViewModel

@{
    ViewData["Title"] = "Edit User Data";
    Guid userId = ViewBag.UserId ?? Guid.Empty;
    bool isPersonal = Model.AccountType == AccountType.Personal;
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card shadow-lg mt-5">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0"><i class="fas fa-user-pen me-2"></i> @ViewData["Title"]</h3>
            </div>
            <div class="card-body">
                <form id="editUserForm"
                      asp-area="Admin"
                      asp-controller="Role"
                      asp-action="Edit"
                      asp-route-id="@userId"
                      asp-antiforgery="true"
                      method="post">
                    <input asp-for="AccountType" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserEmail" class="form-label"></label>
                        <input asp-for="UserEmail" class="form-control" />
                        <span asp-validation-for="UserEmail" class="text-danger mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserPhone" class="form-label"></label>
                        <input asp-for="UserPhone" class="form-control" />
                        <span asp-validation-for="UserPhone" class="text-danger mt-1 d-block"></span>
                    </div>

                    @if (isPersonal)
                    {
                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PersonalNumber" class="form-label"></label>
                            <input asp-for="PersonalNumber" class="form-control" />
                            <span asp-validation-for="PersonalNumber" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DateOfBirth" class="form-label"></label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger mt-1 d-block"></span>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label asp-for="CompanyName" class="form-label"></label>
                            <input asp-for="CompanyName" class="form-control" />
                            <span asp-validation-for="CompanyName" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="VATNumber" class="form-label"></label>
                            <input asp-for="VATNumber" class="form-control" />
                            <span asp-validation-for="VATNumber" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CompanyAddress" class="form-label"></label>
                            <input asp-for="CompanyAddress" class="form-control" />
                            <span asp-validation-for="CompanyAddress" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ContactPersonName" class="form-label"></label>
                            <input asp-for="ContactPersonName" class="form-control" />
                            <span asp-validation-for="ContactPersonName" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ContactPhone" class="form-label"></label>
                            <input asp-for="ContactPhone" class="form-control" />
                            <span asp-validation-for="ContactPhone" class="text-danger mt-1 d-block"></span>
                        </div>
                    }

                    <hr />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-area="Admin" asp-controller="Role" asp-action="Detail" asp-route-id="@userId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Back to User Details
                        </a>
                        <button type="submit" id="saveBtn" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
