@using OrderFlow.Data.Models.Enums
@using OrderFlow.Helpers
@using OrderFlow.ViewModels.User
@model ProfileViewModel

@{
    ViewData["Title"] = "User Details";
    Guid userId = ViewBag.UserId ?? Guid.Empty;
    string role = ViewBag.Role ?? string.Empty;
    bool isPersonal = Model.AccountType == AccountType.Personal;
}

<link rel="stylesheet" href="~/css/role-badges.css" />
<link rel="stylesheet" href="~/css/account-type-badges.css" />
<div class="container py-4" style="max-width: 860px;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <div>
            <i class="fas fa-user text-primary fs-4"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-semibold">@ViewData["Title"]</h4>
            <small class="text-muted">Review and manage this account information</small>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="fas fa-shield-alt text-primary"></i>
                    <span class="fw-semibold">Account Information</span>
                    <span class="ms-auto @AccountTypeBadges.GetAccountTypeBadgeClass(Model.AccountType.ToString())">
                        @if (Model.AccountType.Equals(AccountType.Personal))
                        {
                            <i class="fas fa-user"></i>
                        }
                        else
                        {
                            <i class="fas fa-building"></i>
                        }
                        @Model.AccountType
                    </span>
                </div>
                <div class="card-body px-4 py-4">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-medium">
                                <i class="fas fa-user me-1"></i>User Name
                            </label>
                            <p class="mb-0 fw-medium">@Model.UserName</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-medium">
                                <i class="fas fa-envelope me-1"></i>Email
                            </label>
                            <p class="mb-0 fw-medium">@Model.UserEmail</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-medium">
                                <i class="fas fa-phone me-1"></i>Phone
                            </label>
                            <p class="mb-0 fw-medium">
                                @(string.IsNullOrWhiteSpace(Model.UserPhone) ? "Not provided" : Model.UserPhone)
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-medium">
                                <i class="fas fa-user-tag me-1"></i>Role
                            </label>
                            <div>
                                @if (!string.IsNullOrEmpty(role))
                                {
                                    <div class="dropdown">
                                        <button class="@RoleBadges.GetRoleBadgeClass(role) btn btn-outline-dark btn-sm dropdown-toggle"
                                                type="button"
                                                id="dropdownMenuButton_@userId"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">
                                            <i class="@RoleBadges.GetRoleIconClass(role)"></i> @role
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm"
                                            aria-labelledby="dropdownMenuButton_@userId">
                                            <li><h6 class="dropdown-header">Change role</h6></li>
                                            <li><hr class="dropdown-divider"></li>
                                            @foreach (var roleName in Enum.GetValues(typeof(UserRoles)).Cast<UserRoles>())
                                            {
                                                bool hasRole = role.Contains(roleName.ToString());
                                                <li>
                                                    <form asp-area="Admin"
                                                          asp-antiforgery="true"
                                                          asp-action="ChangeRow"
                                                          asp-controller="Account"
                                                          asp-route-id="@userId"
                                                          asp-route-role="@roleName"
                                                          method="post">
                                                        <button type="submit"
                                                                class="dropdown-item d-flex align-items-center gap-2 @(hasRole ? "active" : "")">
                                                            <i class="@RoleBadges.GetRoleIconClass(roleName.ToString())"></i>
                                                            @if (hasRole)
                                                            {
                                                                <span>Current @roleName</span>
                                                                <i class="fas fa-check ms-auto text-success" style="font-size: 11px;"></i>
                                                            }
                                                            else
                                                            {
                                                                <span>Change to @roleName</span>
                                                            }
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <span class="role-badge role-badge-default fst-italic">No roles assigned</span>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    @if (isPersonal)
                    {
                        <i class="fas fa-user"></i>
                        <span class="fw-semibold">Personal Details</span>
                    }
                    else
                    {
                        <i class="fas fa-building"></i>
                        <span class="fw-semibold">Company Details</span>
                    }
                </div>
                <div class="card-body px-4 py-4">
                    <div class="row g-3">

                        @if (isPersonal)
                        {
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">First Name</label>
                                <p class="mb-0 fw-medium">@Model.FirstName</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Last Name</label>
                                <p class="mb-0 fw-medium">@Model.LastName</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Personal Number</label>
                                <p class="mb-0 fw-medium">@Model.PersonalNumber</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Date of Birth</label>
                                <p class="mb-0 fw-medium">
                                    @(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "Not provided")
                                </p>
                            </div>

                            <div class="col-12">
                                <label class="form-label text-muted small fw-medium">Address</label>
                                <p class="mb-0 fw-medium">@Model.Address</p>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Company Name</label>
                                <p class="mb-0 fw-medium">@Model.CompanyName</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">VAT Number</label>
                                <p class="mb-0 fw-medium">@Model.VATNumber</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Contact Person</label>
                                <p class="mb-0 fw-medium">@Model.ContactPersonName</p>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">Contact Phone</label>
                                <p class="mb-0 fw-medium">@Model.ContactPhone</p>
                            </div>

                            <div class="col-12">
                                <label class="form-label text-muted small fw-medium">Company Address</label>
                                <p class="mb-0 fw-medium">@Model.CompanyAddress</p>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <a class="btn btn-outline-secondary btn-sm"
                   asp-area="Admin"
                   asp-controller="Account"
                   asp-action="Index">
                    <i class="fas fa-arrow-left me-1"></i>Back to Users
                </a>

                <a class="btn btn-primary btn-sm"
                   asp-area="Admin"
                   asp-controller="Account"
                   asp-action="Edit"
                   asp-route-id="@userId">
                    <i class="fas fa-pen me-1"></i>Edit User
                </a>
            </div>
        </div>

    </div>
</div>
