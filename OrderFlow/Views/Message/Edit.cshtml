@{
    var notificationID = Context.Request.RouteValues["id"]?.ToString() ?? "";
}

<div class="modal fade" id="editMessageModal" tabindex="-1"
     aria-labelledby="editMessageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editMessageModalLabel">
                    <i class="fas fa-edit me-2"></i> Edit Message
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editMessageForm" asp-antiforgery="true" method="post" asp-area="" asp-controller="Message" asp-action="Edit">
                <div class="modal-body">
                    <input type="hidden" id="editMessageID"
                           name="NotificationID" value="@notificationID" />
                    <div class="mb-3">
                        <label for="editMessageContent" class="form-label fw-semibold">
                            Message Content
                        </label>
                        <textarea id="editMessageContent"
                                  name="Content"
                                  class="form-control"
                                  rows="4"></textarea>
                        <div class="invalid-feedback">Please enter a message.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
