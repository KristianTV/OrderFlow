@using OrderFlow.ViewModels.Notification
@model IEnumerable<IndexNotificationViewModel>

@{
    string area = ViewData["NotificationArea"]?.ToString() ?? string.Empty;
}

@foreach (var notification in Model ?? Enumerable.Empty<IndexNotificationViewModel>())
{
    <div class="col" data-notification-card data-is-read="@notification.IsRead.ToString().ToLowerInvariant()" data-is-system="@string.IsNullOrEmpty(notification.SenderName).ToString().ToLowerInvariant()">
        <div class="card h-100 shadow-sm @(notification.IsRead ? "border-light" : "border-primary")">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title @(notification.IsRead ? "text-muted" : "text-primary") mb-2">
                    @if (notification.IsRead)
                    {
                        <i class="far fa-envelope-open me-2"></i>
                    }
                    else
                    {
                        <i class="fas fa-envelope me-2"></i>
                    }
                    @notification.Title
                </h5>
                <h6 class="card-subtitle mb-2 text-muted">
                    <i class="far fa-clock me-1"></i> @notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                </h6>
                @if (!string.IsNullOrEmpty(notification.SenderName))
                {
                    <p class="card-text mb-1">
                        <strong><i class="fas fa-user me-1"></i> From:</strong> @notification.SenderName
                    </p>
                }
                else
                {
                    <p class="card-text mb-1">
                        <strong><i class="fas fa-user me-1"></i> From:</strong> System
                    </p>
                }
            </div>
            <div class="card-footer text-end bg-light border-top-0">
                @if (notification.isMarkable)
                {
                    @if (notification.IsRead)
                    {
                        <form asp-antiforgery="true" asp-area="@area" asp-controller="Notification" asp-action="MarkAsUnread" asp-route-id="@notification.NotificationID" method="post" class="d-inline ms-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-eye-slash me-2"></i> Mark as Unread
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-antiforgery="true" asp-area="@area" asp-controller="Notification" asp-action="MarkAsRead" asp-route-id="@notification.NotificationID" method="post" class="d-inline ms-2">
                            <button type="submit" class="btn btn-info">
                                <i class="fas fa-check-circle me-2"></i> Mark as Read
                            </button>
                        </form>
                    }
                }
                <a class="btn btn-primary" asp-area="@area" asp-controller="Notification" asp-action="Detail" asp-route-id="@notification.NotificationID">
                    <i class="fas fa-info-circle me-2"></i> View Details
                </a>
            </div>
        </div>
    </div>
}
