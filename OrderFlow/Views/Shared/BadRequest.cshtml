@model string;

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bad Request</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f3f4f6;
        }

        nav {
        visibility: hidden
        }

        .error-code {
        font-size: 8rem;
        font-weight: 700;
        color: #ef4444;
        text-align: center;
        line-height: 1;
        margin-bottom: 1rem;
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="container mx-auto p-4 flex justify-center items-center min-h-screen">
        <div class="bg-white shadow-xl rounded-lg p-8 md:p-12 max-w-2xl w-full text-center">
            <h1 class="text-red-600 text-4xl md:text-5xl font-extrabold mb-4">Bad Request.</h1>
            <h2 class="text-red-500 text-xl md:text-2xl font-semibold mb-6">@Model</h2>
            <a asp-action="Index" asp-controller="Home" class="btn btn-primary btn-lg">
                <i class="fas fa-home me-2"></i> Go to Homepage
            </a>
        </div>
    </div>
</body>
</html>
