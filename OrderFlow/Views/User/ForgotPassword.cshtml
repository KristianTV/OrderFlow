@using OrderFlow.ViewModels.User
@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-lg">
            <div class="card-header bg-primary text-white text-center">
                <h3 class="mb-0"><i class="fas fa-user-circle me-2"></i> @ViewData["Title"]</h3>
            </div>
            <div class="card-body">
                <section>
                    <form id="account" method="post" asp-action="ForgotPassword">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <div class="mb-3">
                            <label asp-for="@Model.Email" class="form-label"></label>
                            <input asp-for="@Model.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="login-submit" type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-s fa-key me-2"></i> Send Reset Link
                            </button>
                        </div>
                        <div class="mt-3 text-center">
                            <p class="mb-1">
                                <a asp-action="Register" asp-controller="User">Don't have an account? Register here.</a>
                            </p>
                            <p>
                                <a asp-action="Login" asp-controller="User">Already have an account? Log in here.</a>
                            </p>
                        </div>
                    </form>
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
