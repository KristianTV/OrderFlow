@using OrderFlow.Data.Models.Enums
@using OrderFlow.ViewModels.User
@using OrderFlow.Helpers
@model ProfileViewModel
@{
    ViewData["Title"] = "User Profile";
    var isPersonal = Model.AccountType == AccountType.Personal;
    var currentRoles = Enum.GetValues(typeof(UserRoles))
        .Cast<UserRoles>()
        .Select(role => role.ToString())
        .Where(User.IsInRole)
        .ToList();
}

<link rel="stylesheet" href="~/css/role-badges.css" />
<link rel="stylesheet" href="~/css/account-type-badges.css" />

<div class="container py-4" style="max-width: 860px;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <div>
            <i class="fas fa-user text-primary fs-4"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-semibold">@ViewData["Title"]</h4>
            <small class="text-muted">Manage your account information</small>
        </div>
    </div>

    <div id="profileAlert" class="alert d-none mb-4" role="alert"></div>

    <form id="profileForm" asp-antiforgery="true" asp-area="" asp-controller="User" asp-action="Profile" method="post">
        <input type="hidden" id="AccountType" value="@((int)Model.AccountType)" />

        <div class="row g-4">

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                        <i class="fas fa-shield-alt text-primary"></i>
                        <span class="fw-semibold">Account Information</span>
                        <span class="ms-auto @AccountTypeBadges.GetAccountTypeBadgeClass(Model.AccountType.ToString())">
                            @if (Model.AccountType.Equals(AccountType.Personal))
                            {
                                <i class="fas fa-user"></i>
                            }
                            else
                            {
                                <i class="fas fa-building"></i>
                            }
                            @Model.AccountType
                        </span>
                    </div>
                    <div class="card-body px-4 py-4">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label for="UserName" class="form-label text-muted small fw-medium">
                                    <i class="fas fa-user me-1"></i>User Name
                                </label>
                                <p class="mb-0 fw-medium" data-display-for="UserName">@Model.UserName</p>
                                <input id="UserName" class="form-control form-control-sm d-none" value="@Model.UserName" />
                            </div>

                            <div class="col-md-6">
                                <label for="UserEmail" class="form-label text-muted small fw-medium">
                                    <i class="fas fa-envelope me-1"></i>Email
                                </label>
                                <p class="mb-0 fw-medium" data-display-for="UserEmail">@Model.UserEmail</p>
                                <input id="UserEmail" type="email" class="form-control form-control-sm d-none" value="@Model.UserEmail" />
                            </div>

                            <div class="col-md-6">
                                <label for="UserPhone" class="form-label text-muted small fw-medium">
                                    <i class="fas fa-phone me-1"></i>Phone
                                </label>
                                <p class="mb-0 fw-medium" data-display-for="UserPhone">
                                    @(string.IsNullOrWhiteSpace(Model.UserPhone) ? "Not provided" : Model.UserPhone)
                                </p>
                                <input id="UserPhone" class="form-control form-control-sm d-none" value="@Model.UserPhone" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-medium">
                                    <i class="fas fa-user-tag me-1"></i>Roles
                                </label>
                                <div>
                                    @if (currentRoles.Any())
                                    {
                                        @foreach (var role in currentRoles)
                                        {
                                            <span class="role-badge @RoleBadges.GetRoleBadgeClass(role)">
                                                <i class="@RoleBadges.GetRoleIconClass(role)"></i> @role
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="role-badge role-badge-default fst-italic">No roles assigned</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                        @if (isPersonal)
                        {
                            <i class="fas fa-user"></i>
                            <span class="fw-semibold">Personal Details</span>
                        }
                        else
                        {
                            <i class="fas fa-building"></i>
                            <span class="fw-semibold">Company Details</span>
                        }
                    </div>
                    <div class="card-body px-4 py-4">
                        <div class="row g-3">

                            @if (isPersonal)
                            {
                                <div class="col-md-6">
                                    <label for="FirstName" class="form-label text-muted small fw-medium">First Name</label>
                                    <p class="mb-0 fw-medium" data-display-for="FirstName">@Model.FirstName</p>
                                    <input id="FirstName" class="form-control form-control-sm d-none" value="@Model.FirstName" />
                                </div>

                                <div class="col-md-6">
                                    <label for="LastName" class="form-label text-muted small fw-medium">Last Name</label>
                                    <p class="mb-0 fw-medium" data-display-for="LastName">@Model.LastName</p>
                                    <input id="LastName" class="form-control form-control-sm d-none" value="@Model.LastName" />
                                </div>

                                <div class="col-md-6">
                                    <label for="PersonalNumber" class="form-label text-muted small fw-medium">Personal Number</label>
                                    <p class="mb-0 fw-medium" data-display-for="PersonalNumber">@Model.PersonalNumber</p>
                                    <input id="PersonalNumber" class="form-control form-control-sm d-none" value="@Model.PersonalNumber" />
                                </div>

                                <div class="col-md-6">
                                    <label for="DateOfBirth" class="form-label text-muted small fw-medium">Date of Birth</label>
                                    <p class="mb-0 fw-medium" data-display-for="DateOfBirth">
                                        @(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "Not provided")
                                    </p>
                                    <input id="DateOfBirth" type="date" class="form-control form-control-sm d-none"
                                           value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" />
                                </div>

                                <div class="col-12">
                                    <label for="Address" class="form-label text-muted small fw-medium">Address</label>
                                    <p class="mb-0 fw-medium" data-display-for="Address">@Model.Address</p>
                                    <input id="Address" class="form-control form-control-sm d-none" value="@Model.Address" />
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6">
                                    <label for="CompanyName" class="form-label text-muted small fw-medium">Company Name</label>
                                    <p class="mb-0 fw-medium" data-display-for="CompanyName">@Model.CompanyName</p>
                                    <input id="CompanyName" class="form-control form-control-sm d-none" value="@Model.CompanyName" />
                                </div>

                                <div class="col-md-6">
                                    <label for="VATNumber" class="form-label text-muted small fw-medium">VAT Number</label>
                                    <p class="mb-0 fw-medium" data-display-for="VATNumber">@Model.VATNumber</p>
                                    <input id="VATNumber" class="form-control form-control-sm d-none" value="@Model.VATNumber" />
                                </div>

                                <div class="col-md-6">
                                    <label for="ContactPersonName" class="form-label text-muted small fw-medium">Contact Person</label>
                                    <p class="mb-0 fw-medium" data-display-for="ContactPersonName">@Model.ContactPersonName</p>
                                    <input id="ContactPersonName" class="form-control form-control-sm d-none" value="@Model.ContactPersonName" />
                                </div>

                                <div class="col-md-6">
                                    <label for="ContactPhone" class="form-label text-muted small fw-medium">Contact Phone</label>
                                    <p class="mb-0 fw-medium" data-display-for="ContactPhone">@Model.ContactPhone</p>
                                    <input id="ContactPhone" class="form-control form-control-sm d-none" value="@Model.ContactPhone" />
                                </div>

                                <div class="col-12">
                                    <label for="CompanyAddress" class="form-label text-muted small fw-medium">Company Address</label>
                                    <p class="mb-0 fw-medium" data-display-for="CompanyAddress">@Model.CompanyAddress</p>
                                    <input id="CompanyAddress" class="form-control form-control-sm d-none" value="@Model.CompanyAddress" />
                                </div>
                            }

                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <a asp-area="" asp-controller="User" asp-action="ChangePassword"
                       class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-key me-1"></i>Change Password
                    </a>

                    <button id="editProfileButton" type="button" class="btn btn-primary btn-sm">
                        <i class="fas fa-pen me-1"></i>Edit Profile
                    </button>

                    <button id="saveProfileButton" type="submit" class="btn btn-success btn-sm d-none">
                        <i class="fas fa-check me-1"></i>Save Changes
                    </button>

                    <button id="cancelProfileButton" type="button" class="btn btn-outline-secondary btn-sm d-none">
                        Cancel
                    </button>

                    <div class="ms-auto">
                        <button type="button" class="btn btn-outline-danger btn-sm"
                                data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                            <i class="fas fa-trash-alt me-1"></i>Delete Account
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger fw-semibold" id="deleteAccountModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Delete Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="text-muted mb-0">
                    Are you sure you want to permanently delete your account?
                    This action <strong>cannot be undone</strong>.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <form asp-antiforgery="true" asp-area="" asp-controller="User" asp-action="DeleteAccount" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash-alt me-1"></i>Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('profileForm');
            const alertBox = document.getElementById('profileAlert');
            const editButton = document.getElementById('editProfileButton');
            const saveButton = document.getElementById('saveProfileButton');
            const cancelButton = document.getElementById('cancelProfileButton');
            const displayFields = Array.from(form.querySelectorAll('[data-display-for]'));
            const inputs = Array.from(form.querySelectorAll('input.form-control'));
            const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
            const originalValues = new Map(inputs.map(input => [input.id, input.value]));

            function setEditing(isEditing) {
                displayFields.forEach(f => f.classList.toggle('d-none', isEditing));
                inputs.forEach(i => i.classList.toggle('d-none', !isEditing));
                editButton.classList.toggle('d-none', isEditing);
                saveButton.classList.toggle('d-none', !isEditing);
                cancelButton.classList.toggle('d-none', !isEditing);
                alertBox.classList.add('d-none');
            }

            function getPayload() {
                const payload = {
                    UserName: document.getElementById('UserName').value,
                    UserEmail: document.getElementById('UserEmail').value,
                    UserPhone: document.getElementById('UserPhone').value,
                    AccountType: Number(document.getElementById('AccountType').value)
                };
                inputs.forEach(input => {
                    if (!(input.id in payload)) payload[input.id] = input.value || null;
                });
                return payload;
            }

            function showAlert(type, message) {
                alertBox.className = `alert alert-${type}`;
                alertBox.textContent = message;
            }

            editButton.addEventListener('click', () => setEditing(true));

            cancelButton.addEventListener('click', () => {
                inputs.forEach(input => { input.value = originalValues.get(input.id) ?? ''; });
                setEditing(false);
            });

            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                saveButton.disabled = true;

                const response = await fetch('@Url.Action("Profile", "User")', {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(getPayload())
                });

                saveButton.disabled = false;

                if (!response.ok) {
                    const data = await response.json().catch(() => null);
                    const firstError = data?.errors
                        ? Object.values(data.errors).flat()[0]
                        : 'Unable to update profile.';
                    showAlert('danger', firstError);
                    return;
                }

                const data = await response.json();
                inputs.forEach(input => {
                    let val = data[input.id.charAt(0).toLowerCase() + input.id.slice(1)] ?? data[input.id] ?? '';
                    if (input.type === 'date' && val) val = val.substring(0, 10);
                    input.value = val;
                    originalValues.set(input.id, val);
                    const display = form.querySelector(`[data-display-for="${input.id}"]`);
                    if (display) display.textContent = val || 'Not provided';
                });

                setEditing(false);
                showAlert('success', 'Profile updated successfully.');
            });
        })();
    </script>
}
